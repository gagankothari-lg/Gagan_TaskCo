DATABASE_URL=postgresql://...
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
RESEND_API_KEY=re_...
# FROM_EMAIL — optional outbound email sender override; read via ConfigService.get('FROM_EMAIL')
# in email.service.ts, defaults to "LG Desk <noreply@leveragedgrowth.co>" if unset
FROM_EMAIL=LG Desk <noreply@leveragedgrowth.co>
GEMINI_API_KEY=AIza...
# Google Calendar integration (optional) — read by calendar.service.ts (task/project/leave/holiday
# sync) and meetings/google-calendar.service.ts (meeting invites/Meet links). Both no-op without
# these; currently unconfigured/blocked pending a real Google service account.
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=primary
# GOOGLE_DRIVE_FOLDER_ID=1Abc... — reserved for a future Attachments feature (Prisma model exists;
# no controller/service built yet). Not read anywhere in apps/api/src today; do not treat as functional.
FRONTEND_URL=http://localhost:3000
