# ── apps/api production env (Railway) — PLACEHOLDERS ONLY (safe to commit) ──
# Set the real values in the Railway dashboard / CLI, NEVER in this file.

# Database (Neon PostgreSQL) — must include ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX"
JWT_EXPIRES_IN="7d"

# App
NODE_ENV="production"
PORT="3001"                 # Railway overrides this; main.ts reads process.env.PORT
FRONTEND_URL="https://your-app.vercel.app"   # used for the CORS allow-list

# Email (Resend) — auth OTP delivery (optional; OTP no-ops if unset)
RESEND_API_KEY="re_REPLACE_WITH_YOUR_KEY"

# AI (Gemini) — weekly-summary generation (optional; /weekly-summary/generate 400s if unset)
GEMINI_API_KEY="REPLACE_WITH_YOUR_GEMINI_KEY"

# ── Not currently read by the code (documented for parity; wire up if needed) ──
# GEMINI_MODEL="gemini-2.5-flash"        # model id is hardcoded in weekly-summary.service.ts
# FROM_EMAIL="noreply@yourdomain.com"    # from-address is hardcoded in auth.service.ts
# GOOGLE_DRIVE_FOLDER_ID / GOOGLE_SERVICE_ACCOUNT_JSON  # attachments module not built
